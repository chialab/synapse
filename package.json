{
  "name": "@chialab/synapse",
  "version": "4.1.2",
  "type": "module",
  "description": "Application framework built on the top of DNA Web Components.",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./dist/synapse.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "rimraf 'dist' 'types' && yarn types && esbuild src/index.ts --outfile=dist/synapse.js --format=esm --bundle --packages=external --sourcemap --platform=browser",
    "types": "tsc",
    "test": "vitest run",
    "lint": "biome check",
    "pages:build": "vite build"
  },
  "files": [
    "dist",
    "types",
    "LICENSE",
    "README.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chialab/synapse.git"
  },
  "author": "Chialab <dev@chialab.io> (https://www.chialab.it)",
  "dependencies": {
    "@chialab/dna": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.0",
    "@changesets/cli": "^2.22.0",
    "@types/node": "^24.0.0",
    "@vitest/browser": "^4.0.0",
    "@vitest/browser-playwright": "^4.0.17",
    "@vitest/coverage-istanbul": "^4.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "esbuild": "^0.27.0",
    "playwright": "^1.41.1",
    "publint": "^0.3.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  }
}
